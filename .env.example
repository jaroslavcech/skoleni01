# PostgreSQL connection – copy this file to .env and fill in your values.
# If DATABASE_URL is set it takes precedence over the individual variables below.
DATABASE_URL=postgresql://postgres:password@localhost:5432/tasks

# Individual connection variables (used when DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGDATABASE=tasks
PGUSER=postgres
PGPASSWORD=password
